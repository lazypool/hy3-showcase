# Hy3 API 配置
#
# 使用方式：
#   1. 本地部署：vLLM / SGLang 启动后设为 http://localhost:8000/v1
#   2. TokenHub 云端：https://tokenhub.tencentmaas.com/v1
#   3. 腾讯混元 API：https://api.hunyuan.cloud.tencent.com/v1
#
# 留空 API_KEY 自动进入 Mock 模式，无需真实端点即可运行

HY3_API_BASE=https://tokenhub.tencentmaas.com/v1
HY3_API_KEY=
HY3_MODEL=hy3
HY3_MOCK=false
